{
    "name": "jira-pilot",
    "version": "2.2.0",
    "description": "AI powered Jira CLI and MCP server for humans and agents — manage issues, sprints, boards with interactive wizards, multi-provider AI (OpenAI/Gemini/Anthropic), and an 14-tool MCP server for AI assistants",
    "main": "dist/src/index.js",
    "type": "module",
    "bin": {
        "jira": "./dist/bin/jira.js",
        "jira-pilot": "./dist/bin/jira.js"
    },
    "scripts": {
        "clean": "rimraf dist",
        "prebuild": "npm run clean",
        "build": "tsc",
        "start": "node dist/bin/jira.js",
        "start:dev": "tsx bin/jira.ts",
        "mcp": "node dist/bin/jira.js mcp",
        "mcp:dev": "tsx bin/jira.ts mcp",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "link": "npm link",
        "typecheck": "tsc --noEmit"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist/",
        "bin/",
        "src/",
        "README.md",
        "LICENSE"
    ],
    "keywords": [
        "jira",
        "cli",
        "jira-cli",
        "jira-client",
        "jira-api",
        "atlassian",
        "atlassian-jira",
        "ai",
        "ai-cli",
        "openai",
        "gemini",
        "anthropic",
        "claude",
        "gpt",
        "mcp",
        "model-context-protocol",
        "ai-agent",
        "agent",
        "issue-tracker",
        "project-management",
        "task-management",
        "sprint",
        "kanban",
        "scrum",
        "agile",
        "command-line",
        "interactive",
        "terminal",
        "developer-tools",
        "devtools",
        "productivity",
        "workflow",
        "git-integration"
    ],
    "author": {
        "name": "Arul",
        "url": "https://github.com/Aarul5"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Aarul5/jira-pilot.git"
    },
    "bugs": {
        "url": "https://github.com/Aarul5/jira-pilot/issues"
    },
    "homepage": "https://github.com/Aarul5/jira-pilot#readme",
    "license": "ISC",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.26.0",
        "chalk": "^5.3.0",
        "cmd-table": "^0.1.0",
        "commander": "^14.0.3",
        "enquirer": "^2.4.1",
        "ink": "^6.7.0",
        "ink-select-input": "^6.2.0",
        "ink-spinner": "^5.0.0",
        "ink-table": "^3.1.0",
        "ink-text-input": "^6.0.0",
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@types/ink": "^0.5.2",
        "@types/node": "^25.2.3",
        "@types/react": "^19.2.14",
        "@vitest/coverage-v8": "^4.0.18",
        "rimraf": "^6.1.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}