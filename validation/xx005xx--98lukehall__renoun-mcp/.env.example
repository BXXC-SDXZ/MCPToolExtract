# === ReNoUn API Environment Variables ===

# Stripe (required for billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# API Server (optional — defaults shown)
# RENOUN_API_HOST=0.0.0.0
# RENOUN_API_PORT=8080
# RENOUN_CORS_ORIGINS=https://harrisoncollab.com,https://renoun.dev

# Core engine path (required — path to your proprietary core.py)
RENOUN_CORE_PATH=/app/core.py
