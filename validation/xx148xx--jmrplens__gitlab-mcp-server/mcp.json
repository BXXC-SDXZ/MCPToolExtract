{
    "mcpServers": {
        "gitlab": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITLAB_URL",
                "-e",
                "GITLAB_TOKEN",
                "-e",
                "GITLAB_SKIP_TLS_VERIFY",
                "-e",
                "TOOL_SURFACE",
                "-e",
                "CAPABILITY_SURFACE",
                "-e",
                "META_PARAM_SCHEMA",
                "-e",
                "GITLAB_ENTERPRISE",
                "-e",
                "GITLAB_READ_ONLY",
                "-e",
                "GITLAB_SAFE_MODE",
                "-e",
                "EMBEDDED_RESOURCES",
                "-e",
                "EXCLUDE_TOOLS",
                "-e",
                "GITLAB_IGNORE_SCOPES",
                "-e",
                "UPLOAD_MAX_FILE_SIZE",
                "-e",
                "GITLAB_MCP_ALLOWED_IMPORT_DIRS",
                "-e",
                "RATE_LIMIT_RPS",
                "-e",
                "RATE_LIMIT_BURST",
                "-e",
                "AUTO_UPDATE",
                "-e",
                "AUTO_UPDATE_REPO",
                "-e",
                "AUTO_UPDATE_INTERVAL",
                "-e",
                "AUTO_UPDATE_TIMEOUT",
                "-e",
                "LOG_LEVEL",
                "ghcr.io/jmrplens/gitlab-mcp-server:latest",
                "--http=false"
            ],
            "env": {
                "GITLAB_URL": "${GITLAB_URL:-https://gitlab.com}",
                "GITLAB_TOKEN": "${GITLAB_TOKEN}",
                "GITLAB_SKIP_TLS_VERIFY": "${GITLAB_SKIP_TLS_VERIFY:-false}",
                "TOOL_SURFACE": "${TOOL_SURFACE:-dynamic}",
                "CAPABILITY_SURFACE": "${CAPABILITY_SURFACE:-full}",
                "META_PARAM_SCHEMA": "${META_PARAM_SCHEMA:-opaque}",
                "GITLAB_ENTERPRISE": "${GITLAB_ENTERPRISE:-false}",
                "GITLAB_READ_ONLY": "${GITLAB_READ_ONLY:-false}",
                "GITLAB_SAFE_MODE": "${GITLAB_SAFE_MODE:-false}",
                "EMBEDDED_RESOURCES": "${EMBEDDED_RESOURCES:-true}",
                "EXCLUDE_TOOLS": "${EXCLUDE_TOOLS:-}",
                "GITLAB_IGNORE_SCOPES": "${GITLAB_IGNORE_SCOPES:-false}",
                "UPLOAD_MAX_FILE_SIZE": "${UPLOAD_MAX_FILE_SIZE:-2147483648}",
                "GITLAB_MCP_ALLOWED_IMPORT_DIRS": "${GITLAB_MCP_ALLOWED_IMPORT_DIRS:-}",
                "RATE_LIMIT_RPS": "${RATE_LIMIT_RPS:-0}",
                "RATE_LIMIT_BURST": "${RATE_LIMIT_BURST:-40}",
                "AUTO_UPDATE": "${AUTO_UPDATE:-false}",
                "AUTO_UPDATE_REPO": "${AUTO_UPDATE_REPO:-jmrplens/gitlab-mcp-server}",
                "AUTO_UPDATE_INTERVAL": "${AUTO_UPDATE_INTERVAL:-1h}",
                "AUTO_UPDATE_TIMEOUT": "${AUTO_UPDATE_TIMEOUT:-60s}",
                "LOG_LEVEL": "${LOG_LEVEL:-info}"
            }
        }
    }
}
