{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "framework": "nextjs",
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "crons": [
    {
      "path": "/api/cron/outreach-detector",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/calendar-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/cron/db-health",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/ai-knowledge-audit",
      "schedule": "0 5 * * *"
    }
  ]
}
