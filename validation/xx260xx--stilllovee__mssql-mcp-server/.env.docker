# Environment configuration for MSSQL MCP Server Docker deployment

# =============================================================================
# API Key Mapping Configuration
# =============================================================================
# USE_API_KEY_MAPPING=true

# Azure Table Storage Configuration (required when USE_API_KEY_MAPPING=true)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_TABLE_NAME=ApiKeyMappings

# =============================================================================
# Database Configuration
# =============================================================================

# Method 1: Full Connection String (recommended)
# This will be used as the default connection when API key mapping is enabled
# Individual API keys can override this with their own connection strings
# DB_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=your-database;User ID=your-user;Password=your-password;TrustServerCertificate=True;

# Method 2: Individual Parameters (alternative to connection string)
# DB_SERVER=localhost
# DB_DATABASE=ecommerce
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_USE_WINDOWS_AUTH=false
# DB_DRIVER=ODBC Driver 17 for SQL Server
# DB_ENCRYPT=false
# DB_TRUST_SERVER_CERTIFICATE=true

# =============================================================================
# Server Configuration
# =============================================================================

# Optional: Override default port (8123)
# PORT=8123

# =============================================================================
# Security Notes
# =============================================================================

# 1. Never commit this file with real credentials to version control
# 2. Use Docker secrets or external secret management in production
# 3. Ensure Azure Storage Account has appropriate access controls
# 4. Use strong, unique API keys for each client
# 5. Regularly rotate credentials and API keys