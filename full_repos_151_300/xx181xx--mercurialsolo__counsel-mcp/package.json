{
  "name": "counsel-mcp-server",
  "version": "0.2.6",
  "description": "Open-source MCP server for connecting AI agents to the Counsel API",
  "author": "Counsel AI",
  "license": "MIT",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "counsel-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npx smithery build -t stdio",
    "dev": "npx smithery dev",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:check": "node scripts/check-secrets.js",
    "security:check:all": "node scripts/check-secrets.js --all",
    "prepublishOnly": "npm run build && npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "counsel",
    "ai",
    "agent",
    "llm",
    "claude",
    "openai",
    "cursor",
    "vscode",
    "strategic-reasoning",
    "debate"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mercurialsolo/counsel-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mercurialsolo/counsel-mcp/issues"
  },
  "homepage": "https://github.com/mercurialsolo/counsel-mcp#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@smithery/sdk": "^4.0.1",
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@smithery/cli": "^3.0.3",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.52.0",
    "vitest": "^2.0.0"
  }
}
