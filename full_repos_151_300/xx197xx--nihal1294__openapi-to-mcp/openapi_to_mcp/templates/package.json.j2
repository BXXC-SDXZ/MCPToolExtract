{
  "name": "{{ server_name }}",
  "version": "{{ server_version }}",
  "description": "MCP server generated from OpenAPI specification",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc -w & nodemon build/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openapi"
  ],
  "author": "Generated by openapi-to-mcp",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    {%- if runtime_validation == 'input' %}
    "ajv": "^8.18.0",
    {%- endif %}
    "axios": "^1.13.6",
    "dotenv": "^17.3.1"{% if transport == 'streamable-http' %},
    "express": "^5.2.1"
    {% endif %}
  },
  "devDependencies": {
    {% if transport == 'streamable-http' %}"@types/express": "^5.0.6",
    {% endif %}
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
