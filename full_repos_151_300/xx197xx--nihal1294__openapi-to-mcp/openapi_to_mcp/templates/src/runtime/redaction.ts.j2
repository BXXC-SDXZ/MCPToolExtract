const REDACTED_VALUE = '[REDACTED]';
const DEFAULT_REDACTED_HEADERS = new Set([
  'authorization',
  'cookie',
  'proxy-authorization',
  'set-cookie',
  'x-api-key',
]);

export function redactHeaders(
  headers: Record<string, string>,
  configuredNames: Set<string>
): Record<string, string> {
  return Object.fromEntries(
    Object.entries(headers).map(([key, value]) => {
      const normalized = key.toLowerCase();
      const redacted =
        DEFAULT_REDACTED_HEADERS.has(normalized) || configuredNames.has(normalized);
      return [key, redacted ? REDACTED_VALUE : value];
    })
  );
}

export function redactNamedValues(
  values: Record<string, unknown>,
  configuredNames: Set<string>
): Record<string, unknown> {
  return Object.fromEntries(
    Object.entries(values).map(([key, value]) => {
      const normalized = key.toLowerCase();
      return [key, configuredNames.has(normalized) ? REDACTED_VALUE : value];
    })
  );
}

export function redactBodyPaths(value: unknown, paths: string[]): unknown {
  if (!value || typeof value !== 'object' || paths.length === 0) {
    return value;
  }
  const clone = structuredClone(value);
  for (const path of paths) {
    redactAtPath(clone, parsePath(path));
  }
  return clone;
}

function parsePath(path: string): string[] {
  // Ignore empty segments so minor typos like `a..b` degrade predictably.
  return path
    .split('.')
    .map((segment) => segment.trim())
    .filter(Boolean);
}

function redactAtPath(target: unknown, segments: string[]): void {
  if (!target || segments.length === 0) {
    return;
  }
  if (Array.isArray(target)) {
    redactArrayPath(target, segments);
    return;
  }
  if (typeof target !== 'object') {
    return;
  }
  redactObjectPath(target as Record<string, unknown>, segments);
}

function redactArrayPath(target: unknown[], segments: string[]): void {
  const [head, ...rest] = segments;
  if (!head) {
    return;
  }
  if (head === '*') {
    if (rest.length === 0) {
      target.forEach((_, index) => {
        target[index] = REDACTED_VALUE;
      });
      return;
    }
    target.forEach((item) => redactAtPath(item, rest));
    return;
  }
  const index = Number.parseInt(head, 10);
  if (!Number.isInteger(index) || index < 0 || index >= target.length) {
    return;
  }
  if (rest.length === 0) {
    target[index] = REDACTED_VALUE;
    return;
  }
  redactAtPath(target[index], rest);
}

function redactObjectPath(
  target: Record<string, unknown>,
  segments: string[]
): void {
  const [head, ...rest] = segments;
  if (!head) {
    return;
  }
  if (!(head in target)) {
    return;
  }
  if (rest.length === 0) {
    target[head] = REDACTED_VALUE;
    return;
  }
  redactAtPath(target[head], rest);
}
