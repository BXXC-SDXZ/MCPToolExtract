import express from 'express';
import { randomUUID } from 'node:crypto';
import { isInitializeRequest } from '@modelcontextprotocol/sdk/types.js';
import { StreamableHTTPServerTransport } from '@modelcontextprotocol/sdk/server/streamableHttp.js';
import { OpenApiMcpServer } from './server.js';
import * as console from 'console';
import { TOOL_IDENTITY_HEADER } from './runtime/config.js';
import {
  getHeaderValue,
  isHostAllowed,
  isOriginAllowed,
  normalizeAllowedHost,
  sendBadRequest,
} from './runtime/http_transport.js';
import {
  resolveStreamableHttpCallerContext,
  withRequestCallerContext,
} from './runtime/request_context.js';

const HOST = process.env.MCP_HTTP_HOST || '{{ host }}';
const PORT = Number.parseInt(process.env.MCP_HTTP_PORT || '{{ port }}', 10);
const ENDPOINT = process.env.MCP_HTTP_ENDPOINT || '{{ mcp_endpoint }}';
const ALLOWED_ORIGINS = (process.env.MCP_ALLOWED_ORIGINS || 'http://localhost')
  .split(',')
  .map((origin) => origin.trim())
  .filter(Boolean);
const ALLOWED_HOSTS = (process.env.MCP_ALLOWED_HOSTS || '127.0.0.1,localhost')
  .split(',')
  .map((host) => normalizeAllowedHost(host))
  .filter(Boolean);

type SessionContext = {
  serverInstance: OpenApiMcpServer;
  transport: StreamableHTTPServerTransport;
};

const app = express();
const sessions = new Map<string, SessionContext>();

app.disable('x-powered-by');
app.use(express.json({ limit: '1mb' }));

async function createSessionContext(): Promise<SessionContext> {
  let context: SessionContext | undefined;
  const transport = new StreamableHTTPServerTransport({
    sessionIdGenerator: () => randomUUID(),
    enableJsonResponse: true,
    onsessioninitialized: (sessionId) => {
      if (context) {
        sessions.set(sessionId, context);
      }
    },
  });

  const serverInstance = new OpenApiMcpServer();
  context = { serverInstance, transport };

  transport.onclose = () => {
    const sessionId = transport.sessionId;
    if (sessionId) {
      sessions.delete(sessionId);
    }
    if (context?.serverInstance) {
      void context.serverInstance.close().catch((error: unknown) => {
        console.error('Failed to close session MCP server instance:', error);
      });
    }
  };

  await serverInstance.server.connect(transport);
  return context;
}

async function start(): Promise<void> {
  if (!Number.isInteger(PORT) || PORT <= 0) {
    throw new Error(`Invalid MCP_HTTP_PORT value '${process.env.MCP_HTTP_PORT || ''}'`);
  }

  if (!ENDPOINT.startsWith('/')) {
    throw new Error(`Invalid MCP_HTTP_ENDPOINT '${ENDPOINT}'. Must start with '/'.`);
  }

  app.all(ENDPOINT, async (req, res) => {
    const callerContext = resolveStreamableHttpCallerContext(
      req.headers,
      TOOL_IDENTITY_HEADER
    );
    const origin = req.headers.origin;
    if (!isOriginAllowed(origin, ALLOWED_ORIGINS)) {
      res.status(403).json({ error: 'Origin not allowed' });
      return;
    }

    if (!isHostAllowed(req.headers.host, ALLOWED_HOSTS)) {
      res.status(403).json({ error: 'Host not allowed' });
      return;
    }

    const sessionId = getHeaderValue(req.headers['mcp-session-id']);

    try {
      if (req.method === 'POST') {
        if (sessionId) {
          const existing = sessions.get(sessionId);
          if (!existing) {
            sendBadRequest(res, 'Bad Request: Invalid or missing session ID');
            return;
          }
          await withRequestCallerContext(callerContext, async () => {
            await existing.transport.handleRequest(req, res, req.body);
          });
          return;
        }

        if (!isInitializeRequest(req.body)) {
          sendBadRequest(res, 'Bad Request: No valid session ID provided');
          return;
        }

        const sessionContext = await createSessionContext();
        await withRequestCallerContext(callerContext, async () => {
          await sessionContext.transport.handleRequest(req, res, req.body);
        });
        return;
      }

      if (req.method === 'GET' || req.method === 'DELETE') {
        if (!sessionId) {
          sendBadRequest(res, 'Bad Request: Invalid or missing session ID');
          return;
        }

        const existing = sessions.get(sessionId);
        if (!existing) {
          sendBadRequest(res, 'Bad Request: Invalid or missing session ID');
          return;
        }

        await withRequestCallerContext(callerContext, async () => {
          await existing.transport.handleRequest(req, res, req.body);
        });
        return;
      }

      res.status(405).json({
        jsonrpc: '2.0',
        error: {
          code: -32601,
          message: `Method ${req.method} not allowed`,
        },
        id: null,
      });
    } catch (error) {
      console.error('Streamable HTTP request handling failed:', error);
      if (!res.headersSent) {
        res.status(500).json({ error: 'Internal MCP transport error' });
      }
    }
  });

  app.listen(PORT, HOST, () => {
    console.error(`Streamable HTTP MCP server listening on http://${HOST}:${PORT}${ENDPOINT}`);
  });
}

start().catch((error) => {
  console.error('Failed to start streamable-http transport:', error);
  process.exit(1);
});
