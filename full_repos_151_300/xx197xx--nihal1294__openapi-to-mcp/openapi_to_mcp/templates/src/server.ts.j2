import { Server } from '@modelcontextprotocol/sdk/server/index.js';
import {
  CallToolRequestSchema,
  type CallToolResult,
  ErrorCode,
  ListToolsRequestSchema,
  McpError,
} from '@modelcontextprotocol/sdk/types.js';
import * as console from 'console';

import { getCustomTools } from './custom/tools.js';
import {
  type CustomToolDefinition,
  toolRuntimeMap,
  tools,
} from './runtime/generated.js';
import { buildToolErrorResult, ToolExecutionError } from './runtime/errors.js';
import { ToolExecutor } from './runtime/executor.js';
import { createRequestId, logEvent } from './runtime/observability.js';
import {
  assertToolAllowed,
  currentCallerIdentity,
  filterToolsForCaller,
} from './runtime/tool_access.js';

function buildCustomToolMap(): Map<string, CustomToolDefinition> {
  const customToolMap = new Map<string, CustomToolDefinition>();
  for (const customTool of getCustomTools()) {
    const toolName = customTool.tool.name;
    if (toolRuntimeMap.has(toolName)) {
      throw new Error(`Custom tool '${toolName}' conflicts with a generated tool.`);
    }
    if (customToolMap.has(toolName)) {
      throw new Error(`Custom tool '${toolName}' is registered more than once.`);
    }
    customToolMap.set(toolName, customTool);
  }
  return customToolMap;
}

function mergeTools(customToolMap: Map<string, CustomToolDefinition>) {
  return [...tools, ...[...customToolMap.values()].map(({ tool }) => tool)];
}

export class OpenApiMcpServer {
  private static readonly activeInstances = new Set<OpenApiMcpServer>();
  private static shutdownHooksRegistered = false;

  public server: Server;
  private readonly customToolMap = buildCustomToolMap();
  private readonly executor = new ToolExecutor();
  private readonly allTools = mergeTools(this.customToolMap);

  constructor() {
    this.server = new Server(
      { name: '{{ server_name }}', version: '{{ server_version }}' },
      { capabilities: { resources: {}, tools: {} } }
    );
    OpenApiMcpServer.activeInstances.add(this);
    this.setupRequestHandlers();
    OpenApiMcpServer.setupGracefulShutdown();
    this.server.onerror = (error) => console.error('[MCP Server Error]', error);
  }

  public async close(): Promise<void> {
    try {
      await this.server.close();
    } finally {
      OpenApiMcpServer.activeInstances.delete(this);
    }
  }

  private static async shutdownAll(signal: string): Promise<void> {
    const instances = [...OpenApiMcpServer.activeInstances];
    if (instances.length === 0) {
      process.exit(0);
      return;
    }

    const results = await Promise.allSettled(instances.map((instance) => instance.close()));
    const failures = results.filter((result) => result.status === 'rejected');
    if (failures.length > 0) {
      console.error(`Encountered ${failures.length} error(s) while handling ${signal} shutdown.`);
      process.exit(1);
      return;
    }
    process.exit(0);
  }

  private static setupGracefulShutdown(): void {
    if (OpenApiMcpServer.shutdownHooksRegistered) {
      return;
    }
    OpenApiMcpServer.shutdownHooksRegistered = true;
    process.once('SIGINT', () => {
      void OpenApiMcpServer.shutdownAll('SIGINT');
    });
    process.once('SIGTERM', () => {
      void OpenApiMcpServer.shutdownAll('SIGTERM');
    });
  }

  private setupRequestHandlers(): void {
    this.server.setRequestHandler(ListToolsRequestSchema, async () => ({
      tools: filterToolsForCaller(this.allTools),
    }));
    this.server.setRequestHandler(
      CallToolRequestSchema,
      async (request): Promise<CallToolResult> => {
        const toolName = request.params.name;
        const args = (request.params.arguments || {}) as Record<string, unknown>;
        const customTool = this.customToolMap.get(toolName);
        const tool = toolRuntimeMap.get(toolName);
        if (!customTool && !tool) {
          throw new McpError(ErrorCode.MethodNotFound, `Tool '${toolName}' not found.`);
        }
        try {
          assertToolAllowed(toolName);
          if (customTool) {
            return customTool.handler(args);
          }
          return this.executor.execute(toolName, tool!, args);
        } catch (error) {
          if (!(error instanceof ToolExecutionError)) {
            throw error;
          }
          if (error.meta.source !== 'auth') {
            throw error;
          }
          return this.handleDeniedTool(toolName, error);
        }
      }
    );
  }

  private handleDeniedTool(
    toolName: string,
    error: ToolExecutionError
  ): CallToolResult {
    const requestId = createRequestId();
    logEvent('error', 'tool_execution_denied', {
      callerIdentity: currentCallerIdentity(),
      errorCode: error.meta.code,
      errorSource: error.meta.source,
      requestId,
      retryable: error.meta.retryable,
      toolName,
    });
    return buildToolErrorResult(error, requestId);
  }
}
