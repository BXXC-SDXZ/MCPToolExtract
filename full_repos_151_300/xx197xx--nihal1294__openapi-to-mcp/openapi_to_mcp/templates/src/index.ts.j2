#!/usr/bin/env node
import dotenv from 'dotenv';
import path from 'path';
import { fileURLToPath } from 'url';
import * as console from 'console';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const envPath = path.resolve(__dirname, '../.env');

async function bootstrap(): Promise<void> {
  // Keep dotenv's runtime banner off stdout so MCP protocol output stays clean.
  dotenv.config({ path: envPath, quiet: true });
  console.error(`Attempting to load environment variables from: ${envPath}`);
  await import('./transport.js');
}

bootstrap().catch((error) => {
  console.error('Failed to bootstrap MCP server:', error);
  process.exit(1);
});
