# Environment configuration for {{ server_name }}
# Defaults to the first API base URL found in the spec when available.
# Replace if needed for your target environment.
TARGET_API_BASE_URL={{ api_base_url_comment }}

# Optional authorization header in the format 'Header-Name: Value'
#TARGET_API_AUTH_HEADER=Authorization: Bearer YOUR_TOKEN

# Streamable HTTP transport defaults
MCP_HTTP_HOST={{ host }}
MCP_HTTP_PORT={{ port }}
MCP_HTTP_ENDPOINT={{ mcp_endpoint }}
# Comma-separated list of browser origins allowed to call the MCP endpoint.
MCP_ALLOWED_ORIGINS=http://localhost
# Comma-separated list of Host header values (host only, no scheme) accepted by the server.
MCP_ALLOWED_HOSTS=127.0.0.1,localhost

# Runtime execution controls
MCP_PERFORMANCE_PRESET=off
# Explicit runtime env vars below override any preset-expanded defaults.
# Leave them blank to use the built-in defaults or the selected preset as-is.
MCP_MAX_CONCURRENCY=
MCP_PER_TOOL_MAX_CONCURRENCY=
MCP_MAX_QUEUE_SIZE=
MCP_QUEUE_TIMEOUT_MS=
MCP_TOOL_TIMEOUT_MS=
# Safe-method performance controls (`GET`, `HEAD`, `OPTIONS`). Use 0 to disable.
MCP_CACHE_TTL_MS=
MCP_CACHE_MAX_ENTRIES=
MCP_RATE_LIMIT_PER_MINUTE=
# Safe-method resilience controls. Retries require both a positive retry count and
# a positive retry budget. Circuit breaker failure thresholds count consecutive
# retryable failures. Set the threshold to 0 to disable the breaker entirely;
# cooldown only applies when the threshold is positive. Breaker state is process-local
# and resets on restart. One half-open probe is allowed after each cooldown window.
MCP_RETRY_MAX_RETRIES=
MCP_RETRY_BUDGET_PER_MINUTE=
MCP_CIRCUIT_BREAKER_FAILURE_THRESHOLD=
MCP_CIRCUIT_BREAKER_COOLDOWN_MS=

# Tool access control for generated runtimes. Identity values are exact, case-sensitive
# matches; stdio uses the reserved `stdio` identity; invalid JSON fails at startup.
MCP_TOOL_ACCESS_MODE=off
MCP_TOOL_ACCESS_DEFAULT=allow
MCP_TOOL_IDENTITY_HEADER=
MCP_TOOL_ALLOWLISTS=

# Audit logs are emitted on stderr when enabled. Header/query/cookie names are matched
# case-insensitively. Auth-derived cookie values are redacted by default. Body paths
# only apply to JSON object/array payloads and use dot notation with optional '*'.
MCP_AUDIT_MODE=off
MCP_AUDIT_REDACT_HEADERS=
MCP_AUDIT_REDACT_QUERY_PARAMS=
MCP_AUDIT_REDACT_COOKIE_NAMES=
MCP_AUDIT_REDACT_REQUEST_BODY_PATHS=
MCP_AUDIT_REDACT_RESPONSE_BODY_PATHS=

{% if auth_env_vars -%}
# Auth variables derived from OpenAPI security schemes
{% for auth_env in auth_env_vars -%}
{{ auth_env }}=
{% endfor -%}
{% endif -%}
